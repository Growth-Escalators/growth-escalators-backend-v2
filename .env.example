# Growth Escalators CRM — environment variables.
# Copy to .env and fill in real values for local dev. Every key below is
# read somewhere in src/ (mirrored 1:1 via `grep -rho "process.env.[A-Z_]*"`)
# — keep this file in sync when adding a new process.env.X reference.

# ---------------------------------------------------------------------------
# Core / server
# ---------------------------------------------------------------------------
DATABASE_URL=
DATABASE_PUBLIC_URL=              # Railway's public (non-private-network) DB URL, used by local scripts run outside Railway
PORT=
WORKER_PORT=                      # Health-check port for the standalone worker process (only used if run as a separate Railway service)
NODE_ENV=
LOG_LEVEL=                        # pino level: trace|debug|info|warn|error|fatal (default: info)
JWT_SECRET=                       # Signs/verifies session JWTs — required in production
CORS_EXTRA_ORIGIN=                # Extra allowed CORS origin beyond the hardcoded crm./ecom. hosts (e.g. a client preview domain)
FRONTEND_URL=
BACKEND_URL=
BASE_URL=
PUBLIC_API_BASE=
CRM_BASE_URL=
CRM_PUBLIC_HOST=
CRM_EXTRA_HOST=                   # Extra hostname accepted alongside crm.growthescalators.com
BOOKING_URL=
DISABLE_BACKGROUND_JOBS=          # Set true to run the API without in-process crons/workers (e.g. a second scaled-out web instance)
DEFAULT_TENANT_SLUG=              # Tenant slug used by single-tenant bootstrap/backfill code (default: growth-escalators)
GITHUB_TOKEN=                     # Used by scripts/generate-ai-brief.ts to read recent commits, if run outside a git checkout with remote access

# ---------------------------------------------------------------------------
# Slack (team notifications, cron alerts, DMs)
# ---------------------------------------------------------------------------
SLACK_BOT_TOKEN=
SLACK_NOTIFICATIONS_PAUSED=       # Set true to globally mute all Slack sends (maintenance windows)
SLACK_JATIN=
SLACK_SAKCHAM=
SLACK_KESHAV=
SLACK_KANISHK=
SLACK_KRATIKA=
SLACK_SNEHA=
SLACK_GENERAL_CHANNEL=
SLACK_SALES_BD_CHANNEL=
SLACK_OUTREACH_CHANNEL=
SLACK_PERF_MARKETING_CHANNEL=
SLACK_SEO_CHANNEL=
SLACK_SOD_EOD_CHANNEL=
SLACK_SOCIAL_MEDIA_CHANNEL=

# ---------------------------------------------------------------------------
# Cashfree (payments — money path, see AGENTS.md guardrails)
# ---------------------------------------------------------------------------
CASHFREE_APP_ID=
CASHFREE_SECRET_KEY=              # Also used to verify the x-webhook-signature HMAC on incoming payment webhooks
VITE_CASHFREE_ENV=sandbox

# ---------------------------------------------------------------------------
# Meta (Facebook/Instagram — Ads, CAPI, Lead Forms, WhatsApp Business)
# ---------------------------------------------------------------------------
META_ACCESS_TOKEN=
META_ADS_TOKEN=                   # Ads Insights API token (separate from the CAPI/leads access token above)
META_APP_ID=
META_APP_SECRET=                  # Verifies Meta webhook signatures (leads, WhatsApp) — fails closed if unset
META_API_BASE=
META_PHONE_NUMBER_ID=
META_VERIFY_TOKEN=
META_PIXEL_ID=                    # Required for Meta CAPI conversion events to fire
META_CAPI_TOKEN=
META_WABA_ID=
META_BEST_CAMPAIGN_MIN_SPEND=
META_REPORT_ROAS_MIN_SPEND=
FACEBOOK_LEAD_FORM_TENANT_MAP=
FACEBOOK_PAGE_TENANT_MAP=
WIZMATCH_FACEBOOK_LEAD_FORM_IDS=
WIZMATCH_FACEBOOK_PAGE_IDS=
GROWTH_FACEBOOK_LEAD_FORM_IDS=
GROWTH_FACEBOOK_PAGE_IDS=
GE_FACEBOOK_LEAD_FORM_IDS=
GE_FACEBOOK_PAGE_IDS=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# ---------------------------------------------------------------------------
# Email / messaging integrations
# ---------------------------------------------------------------------------
BREVO_API_KEY=                    # Transactional email (purchase confirmations, etc.)
BREVO_LIST_D2C=
SMTP_HOST=
SMTP_USER=
CHATWOOT_API_TOKEN=
CHATWOOT_ACCOUNT_ID=
CHATWOOT_INBOX_ID=
CHATWOOT_WEBHOOK_SECRET=
CALCOM_API_KEY=
CAL_WEBHOOK_SECRET=
TALLY_WEBHOOK_SECRET=
JATIN_WHATSAPP=

# Outreach IMAP reply polling + multi-domain SMTP sending — one mailbox per
# Purelymail sending domain/account. Two separate numbering schemes exist:
# - SMTP send (multiDomainMailer.ts): PURELYMAIL_SMTP_USER_N / _SMTP_PASS_N
#   (falls back to the unprefixed PURELYMAIL_USER_N / _PASS_N below), N=1..6
# - IMAP reply poll (imapService.ts): one PURELYMAIL_PASS_<NAME> per mailbox,
#   e.g. PURELYMAIL_PASS_JATIN_ADSCALELAB, PURELYMAIL_PASS_HELLO_ADSCALELAB
#   — see IMAP_ACCOUNTS in src/services/imapService.ts for the full list.
PURELYMAIL_SMTP_HOST=             # default: smtp.purelymail.com
PURELYMAIL_SMTP_PORT=             # default: 587
PURELYMAIL_SMTP_USER_1=
PURELYMAIL_SMTP_PASS_1=
PURELYMAIL_USER_1=
PURELYMAIL_PASS_1=
PURELYMAIL_PASS_JATIN_ADSCALELAB=
PURELYMAIL_PASS_HELLO_ADSCALELAB=
PURELYMAIL_PASS_JATIN_PARTNERPEAK=
PURELYMAIL_PASS_HELLO_PARTNERPEAK=
PURELYMAIL_PASS_JATIN_PARTNERSGE=
PURELYMAIL_PASS_HELLO_PARTNERSGE=
IMAP_TIMEOUT_MS=

# ---------------------------------------------------------------------------
# Outreach enrichment & sending
# ---------------------------------------------------------------------------
GOOGLE_PLACES_API_KEY=            # Daily outreach lead discovery
HUNTER_API_KEY=                   # Email-finder, primary source
SNOVIO_API_KEY=                   # Email-finder, secondary source (aliased as SNOV_API_KEY in some call sites — set both if unsure)
SNOV_API_KEY=
SNOV_CLIENT_ID=
SNOV_CLIENT_SECRET=
SNOVIO_CLIENT_SECRET=
REACHER_BASE_URL=                 # Email verification service
APOLLO_API_KEY=
SALESHANDY_API_KEY=               # Upload-to-sequence automation
SALESHANDY_SEQUENCE_ID=
MAX_DAILY_UPLOADS=                # default: 200 — daily cap safety-net for uploadToSaleshandy
OUTREACH_INTERNAL_SECRET=         # n8n ↔ backend shared secret for outreach endpoints
OUTBOUND_AUTO_CONVERT_INTERESTED=
OUTBOUND_DEFAULT_PIPELINE_ID=
MEETING_BOOKING_URL=              # Included in INTERESTED-reply drafts as a self-book link

# ---------------------------------------------------------------------------
# SEO / rank tracking / AI intelligence
# ---------------------------------------------------------------------------
SERPER_API_KEY=                   # SEO rank tracking, backlinks, content gaps, outreach directory scraping
ANTHROPIC_API_KEY=
CLAUDE_API_KEY=                   # Alias accepted alongside ANTHROPIC_API_KEY
WP_AGEDDENTISTRY_URL=             # default: https://ageddentistry.org
WP_AGEDDENTISTRY_USER=
WP_AGEDDENTISTRY_PASS=
WP_AGEDDENTISTRY_PASSWORD=

# ---------------------------------------------------------------------------
# Billing / invoicing (India GST)
# ---------------------------------------------------------------------------
COMPANY_GSTIN=
DEFAULT_SAC_CODE=                 # default: 9983
GE_BANK_ACCOUNT=
GE_BANK_IFSC=

# ---------------------------------------------------------------------------
# Storage (Cloudflare R2) & file uploads
# ---------------------------------------------------------------------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=                   # Public bucket (marketing media) — default: ge-media
R2_PUBLIC_URL=
R2_PRIVATE_BUCKET_NAME=          # Private bucket (RTR/consent/sheets + contracts) — REQUIRED, no default; private R2 helpers throw without it
TASK_ATTACHMENT_DIR=              # default: <cwd>/storage/task-attachments

# ---------------------------------------------------------------------------
# Social account OAuth (Instagram/Facebook posting)
# ---------------------------------------------------------------------------
SOCIAL_ENCRYPTION_KEY=            # Encrypts stored OAuth tokens at rest — falls back to JWT_SECRET if unset

# ---------------------------------------------------------------------------
# Edge queue (Vercel edge function → Railway event drain via Upstash Redis)
# ---------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
EDGE_DRAINER_ENABLED=
EDGE_DRAINER_POLL_MS=
EDGE_QUEUE_STREAM=                # default: crm:events
EDGE_QUEUE_GROUP=
EDGE_QUEUE_CONSUMER=
EDGE_QUEUE_DLQ=

# ---------------------------------------------------------------------------
# Blocker alerts
# ---------------------------------------------------------------------------
BLOCKER_THRESHOLD_DAYS=           # default: 2
CRITICAL_THRESHOLD_DAYS=          # default: 5

# ---------------------------------------------------------------------------
# n8n
# ---------------------------------------------------------------------------
N8N_BASE_URL=
N8N_API_KEY=

# ---------------------------------------------------------------------------
# Ad spend monitoring
# ---------------------------------------------------------------------------
SPEND_ALERT_COOLDOWN_HOURS=

# ---------------------------------------------------------------------------
# Wizmatch — sourcing, cost caps, discovery providers
# ---------------------------------------------------------------------------
WIZMATCH_TENANT_ID=
WIZMATCH_INTERNAL_TOKEN=          # x-internal-secret carve-out for the scraper's signal-ingest endpoint
WIZMATCH_INDIA_ONLY=
WIZMATCH_PAID_DISCOVERY_ENABLED=false
WIZMATCH_GOOGLE_FALLBACK_ENABLED=false
WIZMATCH_MAX_PAID_DISCOVERY_PER_COMPANY=1
WIZMATCH_MAX_CONTACT_CANDIDATES_SHOWN=3
WIZMATCH_DISCOVERY_COOLDOWN_DAYS=30
WIZMATCH_COST_CURRENCY=INR
WIZMATCH_MONTHLY_DISCOVERY_BUDGET_CENTS=500000
WIZMATCH_DAILY_DISCOVERY_BUDGET_CENTS=50000
WIZMATCH_MAX_PAID_RUNS_PER_TENANT_DAY=20
WIZMATCH_MAX_PAID_RUNS_PER_USER_DAY=5
WIZMATCH_MAX_APOLLO_CALLS_PER_TENANT_DAY=50
WIZMATCH_MAX_SNOV_CALLS_PER_TENANT_DAY=50
WIZMATCH_MAX_REACHER_CALLS_PER_TENANT_DAY=150
WIZMATCH_MAX_GOOGLE_FALLBACK_CALLS_PER_TENANT_DAY=25
WIZMATCH_APOLLO_COST_CENTS=1500
WIZMATCH_SNOV_COST_CENTS=1000
WIZMATCH_REACHER_COST_CENTS=200
WIZMATCH_GOOGLE_FALLBACK_COST_CENTS=100
SEARCHAPI_API_KEY=                # X-Ray / POC discovery search provider
THEIRSTACK_API_KEY=
WIZMATCH_STAFFING_GATE_A_ENABLED=

# ---------------------------------------------------------------------------
# Wizmatch — outbound sending (brand identity, deliverability, admin)
# ---------------------------------------------------------------------------
WIZMATCH_SENDING_ENABLED=
WIZMATCH_BOUNCE_SUPPRESSION_ENABLED=
WIZMATCH_UNSUBSCRIBE_HMAC_SECRET=
WIZMATCH_DKIM_SELECTORS=          # JSON map of sending domain → DKIM selector list
WIZMATCH_WARMUP_CONTACTS=
WIZMATCH_BRAND_NAME=
WIZMATCH_BRAND_TAGLINE=
WIZMATCH_BRAND_ACCENT=
WIZMATCH_BRAND_EMAIL=
WIZMATCH_BRAND_PHONE=
WIZMATCH_BRAND_WEBSITE=
WIZMATCH_PHYSICAL_ADDRESS=
WIZMATCH_MEETING_URL=
WIZMATCH_API_BASE_URL=
WIZMATCH_ADMIN_NAME=
WIZMATCH_ADMIN_EMAIL=
WIZMATCH_ADMIN_PASSWORD=
WIZMATCH_ANTHROPIC_API_KEY=       # Falls back to ANTHROPIC_API_KEY if unset
WIZMATCH_DAILY_CHANNEL=
WIZMATCH_LEADS_CHANNEL=
WIZMATCH_SYSTEM_CHANNEL=

# ---------------------------------------------------------------------------
# Contracts & E-Signature (Documenso CE signing engine — see docs/esign/)
# Documenso runs as a SEPARATE service with its own DB. The CRM talks to it
# server-to-server only; none of these reach the frontend.
# ---------------------------------------------------------------------------
DOCUMENSO_API_URL=                # Base URL of the self-hosted Documenso instance (e.g. http://localhost:3030 in local dev)
DOCUMENSO_API_TOKEN=              # Documenso API token for server-to-server calls — never exposed to the browser
DOCUMENSO_WEBHOOK_SECRET=         # HMAC secret to verify incoming Documenso webhooks — fails closed if unset
DOCUMENSO_EMBED_ORIGIN=           # Origin allowed to embed the Documenso signing iframe (e.g. https://crm.growthescalators.com)
ESIGN_PROVIDER=                   # Active e-sign provider: documenso (default) | mock (tests/local without a Documenso instance)
CONTRACTS_SIGNING_SECRET=         # HMAC secret for per-recipient signed signing links (no login) — fails closed if unset
CONTRACTS_SIGNED_URL_TTL_SECONDS= # Completed-document download link lifetime (default 300; hard cap 900 in r2.ts)
CONTRACTS_REMINDER_INTERVAL_DAYS= # Days between signing reminders to an unsigned recipient (default 3)
CONTRACTS_STORAGE=                # 'local' → store contract PDFs on local disk (dev/E2E ONLY — Railway disk is ephemeral); unset → Cloudflare R2 (prod)
CONTRACTS_STORAGE_DIR=            # Local storage root when CONTRACTS_STORAGE=local (default <cwd>/storage/contracts)
ESIGN_MOCK_AUTOSIGN=             # '1' → the mock e-sign provider auto-signs on signing-session creation (local/E2E only)
CONTRACT_GE_LEGAL_ENTITY=         # Placeholder: Growth Escalators legal signing entity name (fill before production use)
CONTRACT_WIZMATCH_LEGAL_ENTITY=   # Placeholder: Wizmatch legal signing entity name (fill before production use)
CONTRACT_SIGNING_DOMAIN=          # Placeholder: branded signing domain (e.g. sign.growthescalators.com)
