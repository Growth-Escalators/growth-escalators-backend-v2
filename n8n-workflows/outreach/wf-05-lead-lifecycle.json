    {
      "id": "80d8c90a-afa4-4255-9e84-d47fceb06c63",
      "name": "Code: Format Summary",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2880,
        300
      ],
      "parameters": {
        "jsCode": "\nconst healthRows = $input.all().map(r => r.json);\nconst reData = $('Code: Build Re-engage').first().json;\nconst arData = $('Code: Build Archive').first().json;\n\n// Build status map\nconst sc = {};\nhealthRows.forEach(r => { sc[r.status] = r.cnt || 0; });\n\nconst activeCount = (sc['Active'] || 0) + (sc['Enriching'] || 0);\nconst newCount = sc['New'] || 0;\nconst repliedCount = sc['Replied'] || 0;\n\nconst summary = [\n  '\u250c\u2500 Lead Lifecycle Manager \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500',\n  '\u2502 Re-engaged: ' + reData.reengageCount + ' leads (90-day NOT_NOW cycle)',\n  '\u2502 Archived: ' + arData.archiveCount + ' leads (30-day closed cleanup)',\n  '\u2502 Pipeline health: ' + activeCount + ' active | ' + newCount + ' new | ' + repliedCount + ' replied',\n  '\u2514\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500'\n].join('\\n');\n\nreturn [{ json: { summary } }];\n"
      }
    },
