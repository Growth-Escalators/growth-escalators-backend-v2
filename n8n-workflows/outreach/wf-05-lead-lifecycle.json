            {
              "id": "faa3c75b-ccbf-4d9c-aba5-a9ca81895e08",
              "leftValue": "={{ $('Code: Build Re-engage').first().json.reengageCount }}",
              "rightValue": 0,
              "operator": {
                "type": "number",
                "operation": "gt"
              }
