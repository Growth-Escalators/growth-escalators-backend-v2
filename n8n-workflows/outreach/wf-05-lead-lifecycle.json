    {
      "id": "cc932126-2480-4bb4-bbc4-ce41809b9683",
      "name": "PG: Find Re-engage Leads",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
        460,
        300
      ],
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT id, company, email, first_name, notes FROM outreach_leads WHERE reply_category = 'NOT_NOW' AND status = 'Replied' AND updated_at < NOW() - INTERVAL '90 days'",
        "options": {}
      },
      "credentials": {
        "postgres": {
          "id": "tEi1y3q2RyS0OOgV",
          "name": "GE Outreach Postgres"
        }
      },
      "onError": "continueRegularOutput"
    },
    {
      "id": "a775b66b-62e7-4fba-93cb-046b573dd81d",
      "name": "Code: Build Re-engage",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        680,
        300
      ],
      "parameters": {
        "jsCode": "\nconst leads = $input.all().map(r => r.json);\nconst count = leads.length;\n\nif (count === 0) {\n  return [{ json: { reengageCount: 0, reengageCompanies: [], reengageSql: \"SELECT 1 AS noop\" } }];\n}\n\nconst companies = leads.map(l => l.company || 'Unknown');\nconst ids = leads.map(l => \"'\" + String(l.id).replace(/'/g, \"''\") + \"'\").join(',');\nconst sql = \"UPDATE outreach_leads SET status = 'New', reply_category = NULL, \" +\n  \"notes = CONCAT(COALESCE(notes, ''), ' | Re-engaged on ', CURRENT_DATE, ' (90-day cycle)'), \" +\n  \"updated_at = NOW() WHERE id IN (\" + ids + \") RETURNING id, company\";\n\nreturn [{ json: { reengageCount: count, reengageCompanies: companies, reengageSql: sql } }];\n"
      }
    },
    {
      "id": "31a76e32-c18f-4798-909a-9852c32a477e",
      "name": "PG: Execute Re-engage",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
        900,
        300
      ],
      "parameters": {
        "operation": "executeQuery",
        "query": "={{ $json.reengageSql }}",
        "options": {}
      },
      "credentials": {
        "postgres": {
          "id": "tEi1y3q2RyS0OOgV",
          "name": "GE Outreach Postgres"
        }
      },
      "onError": "continueRegularOutput"
    },
    {
      "id": "d0604e5c-338d-4b6d-b47f-ea1ed69a1ebc",
