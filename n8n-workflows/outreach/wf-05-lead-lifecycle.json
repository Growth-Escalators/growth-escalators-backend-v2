      "name": "Code: Build Archive",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1780,
        300
      ],
      "parameters": {
        "jsCode": "\nconst leads = $input.all().map(r => r.json);\nconst count = leads.length;\n\nif (count === 0) {\n  return [{ json: { archiveCount: 0, archiveCompanies: [], archiveSql: \"SELECT 1 AS noop\" } }];\n}\n\nconst companies = leads.map(l => l.company || 'Unknown');\nconst ids = leads.map(l => \"'\" + String(l.id).replace(/'/g, \"''\") + \"'\").join(',');\nconst sql = \"UPDATE outreach_leads SET status = 'Archived', \" +\n  \"notes = CONCAT(COALESCE(notes, ''), ' | Auto-archived on ', CURRENT_DATE), \" +\n  \"updated_at = NOW() WHERE id IN (\" + ids + \") RETURNING id, company\";\n\nreturn [{ json: { archiveCount: count, archiveCompanies: companies, archiveSql: sql } }];\n"
      }
    },
