    {
      "id": "cae7049f-f81c-4803-81b0-80c17a64e880",
      "name": "Code: Deduplicate Queries",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1780,
        300
      ],
      "parameters": {
        "jsCode": "\nconst resp = $input.first().json;\nconst searches = resp.searches || [];\n\n// Deduplicate by query+location+country, keep most recent\nconst seen = new Map();\nfor (const s of searches) {\n  const key = (s.query + '|' + s.location + '|' + s.country).toLowerCase();\n  if (!seen.has(key)) {\n    seen.set(key, s);\n  }\n}\n\nconst unique = [...seen.values()].slice(0, 10); // max 10\nconst token = $('Code: Extract Token').first().json.token;\n\nif (unique.length === 0) {\n  return [{ json: { hasQueries: false, token, queries: [] } }];\n}\n\n// Return one item per query for SplitInBatches\nreturn unique.map(q => ({\n  json: {\n    hasQueries: true,\n    token,\n    searchQuery: q.query,\n    searchLocation: q.location,\n    searchCountry: q.country || 'UK'\n  }\n}));\n"
      }
    },
