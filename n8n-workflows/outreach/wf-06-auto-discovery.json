    {
      "id": "e7024d90-0f54-4605-b33e-fb8afaf4e2f2",
      "name": "Code: Process Results",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2880,
        300
      ],
      "parameters": {
        "jsCode": "\nconst resp = $input.first().json;\nconst token = $('Code: Extract Token').first().json.token;\nconst sd = $getWorkflowStaticData('global');\n\nsd.queriesRun = (sd.queriesRun || 0) + 1;\n\nif (resp.error) {\n  sd.failedQueries = (sd.failedQueries || 0) + 1;\n  return [{ json: { token, qualifiedIds: [], qualifiedCount: 0, hasQualified: false } }];\n}\n\nconst results = resp.results || [];\nconst totalFound = results.length;\nsd.totalDiscovered = (sd.totalDiscovered || 0) + totalFound;\n\n// Filter: qualified (score >= 70) AND not already imported\nconst qualified = results.filter(r => r.fitScore >= 70 && !r.imported);\nconst duplicatesSkipped = results.filter(r => r.imported).length;\nsd.totalQualified = (sd.totalQualified || 0) + qualified.length;\nsd.totalDuplicatesSkipped = (sd.totalDuplicatesSkipped || 0) + duplicatesSkipped;\nsd.runCost = (sd.runCost || 0) + parseFloat(resp.costUsd || 0);\n\n// Track top finds\nconst topFinds = sd.topFinds || [];\nfor (const r of qualified.slice(0, 3)) {\n  topFinds.push({ name: r.companyName, country: r.address || '', score: r.fitScore });\n}\nsd.topFinds = topFinds.slice(0, 5);\n\nconst ids = qualified.map(r => r.id);\n\nreturn [{ json: { token, qualifiedIds: ids, qualifiedCount: ids.length, hasQualified: ids.length > 0 } }];\n"
      }
    },
