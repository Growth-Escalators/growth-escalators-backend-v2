    {
      "id": "e9be209e-c24b-48f7-bd56-ad6067d4e58d",
      "name": "Code: Format Report",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2660,
        600
      ],
      "parameters": {
        "jsCode": "\nconst budget = $input.first().json;\nconst sd = $getWorkflowStaticData('global');\n\nconst queriesRun = sd.queriesRun || 0;\nconst totalDiscovered = sd.totalDiscovered || 0;\nconst totalQualified = sd.totalQualified || 0;\nconst totalImported = sd.totalImported || 0;\nconst dupsSkipped = sd.totalDuplicatesSkipped || 0;\nconst runCost = (sd.runCost || 0).toFixed(2);\nconst monthlyCost = parseFloat(budget.costUsd || 0).toFixed(2);\nconst topFinds = sd.topFinds || [];\n\nlet topFindsText = '';\nif (topFinds.length > 0) {\n  topFindsText = '\u2502\\n\u2502 Top finds:\\n';\n  for (const f of topFinds.slice(0, 3)) {\n    topFindsText += '\u2502 \u2022 ' + f.name + ' \u2014 score ' + f.score + '\\n';\n  }\n}\n\nconst report = [\n  '\u250c\u2500 Weekly Auto-Discovery Report \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500',\n  '\u2502 Queries re-run: ' + queriesRun,\n  '\u2502 New leads discovered: ' + totalDiscovered,\n  '\u2502 Qualified: ' + totalQualified + ' | Imported: ' + totalImported,\n  '\u2502 Duplicates skipped: ' + dupsSkipped,\n  '\u2502 API cost this run: $' + runCost,\n  '\u2502 Monthly API budget: $' + monthlyCost + ' / $200.00',\n  topFindsText ? topFindsText.trimEnd() : '',\n  '\u2514\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500'\n].filter(Boolean).join('\\n');\n\n// Clean up static data\nsd.queriesRun = 0;\nsd.totalDiscovered = 0;\nsd.totalQualified = 0;\nsd.totalImported = 0;\nsd.totalDuplicatesSkipped = 0;\nsd.runCost = 0;\nsd.topFinds = [];\nsd.failedQueries = 0;\n\nreturn [{ json: { report, totalImported } }];\n"
      }
    },
