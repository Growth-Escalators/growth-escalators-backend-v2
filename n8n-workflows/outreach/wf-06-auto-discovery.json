      "parameters": {
        "jsCode": "\nconst resp = $input.first().json;\nconst token = resp.token || '';\nif (!token) {\n  return [{ json: { token: '', error: 'Login failed: ' + JSON.stringify(resp) } }];\n}\n// Reset tracking data for this run\nconst sd = $getWorkflowStaticData('global');\nsd.queriesRun = 0;\nsd.totalDiscovered = 0;\nsd.totalQualified = 0;\nsd.totalImported = 0;\nsd.totalDuplicatesSkipped = 0;\nsd.runCost = 0;\nsd.topFinds = [];\nsd.failedQueries = 0;\nreturn [{ json: { token } }];\n"
      }
    },
