      "parameters": {
        "jsCode": "\nconst budget = $input.first().json;\nconst token = $('Code: Extract Token').first().json.token;\nconst costUsd = parseFloat(budget.costUsd || 0);\nconst budgetOk = costUsd < 150; // 75% of $200\nreturn [{ json: { token, costUsd, budgetOk, budgetPct: budget.pctUsed || 0 } }];\n"
      }
